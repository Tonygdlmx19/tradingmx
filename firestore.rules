rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Admin: email en la lista Y verificado (Google sign-in siempre verifica)
    function isAdmin() {
      return isAuthenticated()
        && request.auth.token.email_verified == true
        && request.auth.token.email.lower() in ['tonytrader19@gmail.com'];
    }

    // El documento pertenece al email del usuario autenticado
    function ownsEmailDoc(email) {
      return isAuthenticated() && request.auth.token.email.lower() == email;
    }

    // Users config - users can only access their own config
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Trades - users can only access their own trades
    match /trades/{tradeId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Movements - users can only access their own movements
    match /movements/{movementId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Pre-trade analyses - users can only access their own
    match /pretrade_analyses/{docId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // AI query tracking (post-trade)
    match /ai_queries/{docId} {
      allow read, write: if isAuthenticated() && docId.matches(request.auth.uid + '_.*');
    }

    // AI query tracking (pre-trade)
    match /ai_queries_pretrade/{docId} {
      allow read, write: if isAuthenticated() && docId.matches(request.auth.uid + '_.*');
    }

    // Funding challenges - users can only access their own
    match /funding_challenges/{challengeId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Funding trades - users can only access their own
    match /funding_trades/{tradeId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Academy progress - users can only access their own
    match /academy_progress/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Diary entries - users can only access their own
    match /diary_entries/{entryId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Authorized users - cada quien lee SOLO su propio documento; el admin todo
    match /authorized_users/{email} {
      allow get: if ownsEmailDoc(email) || isAdmin();
      allow list: if isAdmin();

      // Crear: solo el propio trial (activo, máx 16 días) o el admin
      allow create: if isAdmin() || (
        ownsEmailDoc(email)
        && request.resource.data.type == 'trial'
        && request.resource.data.status == 'active'
        && request.resource.data.trialEnd is timestamp
        && request.resource.data.trialEnd < request.time + duration.value(16, 'd')
      );

      // Actualizar el propio documento: solo transiciones legítimas de trial
      allow update: if isAdmin() || (
        ownsEmailDoc(email)
        && request.resource.data.type == 'trial'
        && (
          // 1) Marcar como expirado (u otro estado no activo) sin tocar el vencimiento
          (
            request.resource.data.status != 'active'
            && request.resource.data.get('trialEnd', null) == resource.data.get('trialEnd', null)
          )
          // 2) Activar la prueba gratis por primera vez (una sola vez por email)
          || (
            request.resource.data.status == 'active'
            && resource.data.get('trialUsed', false) != true
            && request.resource.data.trialUsed == true
            && request.resource.data.trialEnd is timestamp
            && request.resource.data.trialEnd < request.time + duration.value(16, 'd')
          )
          // 3) Reactivar canjeando un código nuevo y sin usar
          || (
            request.resource.data.status == 'active'
            && request.resource.data.codeUsed is string
            && request.resource.data.codeUsed != resource.data.get('codeUsed', '')
            && exists(/databases/$(database)/documents/trial_codes/$(request.resource.data.codeUsed))
            && get(/databases/$(database)/documents/trial_codes/$(request.resource.data.codeUsed)).data.used != true
            && request.resource.data.trialEnd is timestamp
            && request.resource.data.trialEnd < request.time + duration.value(16, 'd')
          )
        )
      );

      // Only admins can delete
      allow delete: if isAdmin();
    }

    // Market tracker - shared data, admin writes, all authenticated read
    match /market_tracker/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Tracker AI analyses - shared, admin writes, all authenticated read
    match /tracker_analyses/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Trial codes - se puede consultar un código exacto, pero no listarlos todos
    match /trial_codes/{code} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();

      // Un usuario solo puede marcar como usado (por él mismo) un código sin usar
      allow update: if isAdmin() || (
        isAuthenticated()
        && resource.data.used != true
        && request.resource.data.used == true
        && request.resource.data.usedBy == request.auth.token.email.lower()
      );
      // Only admins can create/delete codes
      allow create, delete: if isAdmin();
    }
  }
}
